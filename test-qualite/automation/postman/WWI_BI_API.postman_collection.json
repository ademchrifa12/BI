  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const threshold = Number(pm.variables.get('max_response_time_ms') || 1500);",
          "pm.variables.set('max_response_time_ms', threshold);"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Auth - Login (Firebase)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 or 401', function () {",
                  "  pm.expect([200, 401]).to.include(pm.response.code);",
                  "});",
                  "",
                  "pm.test('Response time under threshold', function () {",
                  "  const threshold = Number(pm.variables.get('max_response_time_ms') || 1500);",
                  "  pm.expect(pm.response.responseTime).to.be.below(threshold);",
                  "});",
                  "",
                  "let body = {};",
                  "try { body = pm.response.json(); } catch (e) { body = {}; }",
                  "",
                  "if (pm.response.code === 200 && body && body.token) {",
                  "  pm.collectionVariables.set('jwt_token', body.token);",
                  "}",
                  "",
                  "pm.test('When 200, response contains success and token', function () {",
                  "  if (pm.response.code === 200) {",
                  "    pm.expect(body).to.have.property('success');",
                  "    pm.expect(body.success).to.eql(true);",
                  "    pm.expect(body).to.have.property('token');",
                  "  }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idToken\": \"{{firebase_id_token}}\"\n}"
            },
            "url": {
              "raw": "{{api_base}}/auth/login",
              "host": [
                "{{api_base}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Auth - Me",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
